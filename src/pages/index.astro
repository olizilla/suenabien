---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const posts = await getCollection('instagram', ({ data }) => data.draft !== true);
const sortedPosts = posts.sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime());

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-GB', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
  }).replace(/\//g, '.');
};
---

<Layout>
		<header class="max-w-xl mx-auto my-8 text-center">
			<img class="mx-auto"
						src="/suenabien.png"
						alt="Suena Bien Logo"
						width={128}
						height={128} />
		</header>

		<div class="max-w-4xl mx-auto px-2">
		  <iframe class="aspect-video" width="100%" src="https://www.youtube.com/embed/zNbjgIjs-VE?si=Q9t8TW88GV_WZQre" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
		</div>
		<div class="max-w-4xl mx-auto my-8 px-2 grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
      {sortedPosts.map((post) => {
        const hasDetails = post.data.caption || (post.data.mediaType === 'CAROUSEL_ALBUM' && post.data.localImages && post.data.localImages.length > 1);
        return (
          <figure class="post-card bg-white rounded-sm mb-0">
            {post.data.localImage && (
              <div class="p-0 pb-2">
                <Image 
                  class="main-post-image bg-white border-gray-100  w-full aspect-[3/4] object-cover cursor-pointer"
                  src={post.data.localImage}
                  alt={post.data.caption || 'Instagram post'}
                  width={600}
                  height={800}
                />
              </div>
            )}

            <figcaption class="px-4 py-4 pt-2">
              {hasDetails ? (
                <details class="text-gray-800 leading-relaxed group">
                  <summary class="flex items-center justify-between cursor-pointer select-none list-none focus:outline-none hover:text-gray-700 [&::-webkit-details-marker]:hidden w-full">
                    <span class="text-sm text-gray-500 font-bold flex items-center gap-1">
                      <span>Details</span>
                      <svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                      </svg>
                    </span>
                    <time class="text-sm text-gray-500 font-normal" datetime={post.data.timestamp.toISOString()}>
                      {formatDate(post.data.timestamp)}
                    </time>
                  </summary>
                  
                  <div class="mt-4 text-sm text-gray-700">
                    {post.data.mediaType === 'CAROUSEL_ALBUM' && post.data.localImages && post.data.localImages.length > 1 && (
                      <div class="pb-4 flex overflow-x-auto gap-2">
                        {post.data.localImages.map((img, idx) => (
                          <button 
                            type="button" 
                            class="thumbnail-btn flex-shrink-0 bg-white border border-gray-100 w-16 h-16 rounded-sm overflow-hidden focus:outline-none cursor-pointer transition-all hover:opacity-80 active:scale-95"
                            data-index={idx}
                          >
                            <Image 
                              class="w-full h-full object-cover"
                              src={img}
                              alt={`Carousel slide ${idx + 1}`}
                              width={600}
                              height={800}
                            />
                          </button>
                        ))}
                      </div>
                    )}

                    {post.data.caption && (
                      <p class="whitespace-pre-wrap mb-4">
                        {post.data.caption}
                      </p>
                    )}
                    
                    <a 
                      href={post.data.permalink} 
                      target="_blank" 
                      rel="noopener noreferrer" 
                      class="inline-block text-sm text-blue-500 font-bold hover:underline"
                    >
                      View on Instagram →
                    </a>
                  </div>
                </details>
              ) : (
                <div class="flex items-center justify-between w-full mt-2">
                  <a 
                    href={post.data.permalink} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="text-sm text-blue-500 font-bold hover:underline"
                  >
                    View on Instagram →
                  </a>
                  <time class="text-sm text-gray-500" datetime={post.data.timestamp.toISOString()}>
                    {formatDate(post.data.timestamp)}
                  </time>
                </div>
              )}
            </figcaption>
          </figure>
        );
      })}

      {sortedPosts.length === 0 && (
        <div class="text-center p-8 bg-white rounded-sm mb-8 text-gray-600 md:col-span-2">
          <p class="font-bold mb-2">No posts synced yet!</p>
          <p class="text-sm">Run <code>npm run sync:instagram</code> to pull content from Instagram.</p>
        </div>
      )}
		</div>

	<div class="max-w-xl mx-auto my-12">
		<figure class="bg-white rounded-sm">
			<div class="p-4">
				<div class="bg-black border-gray-100 border aspect-square flex flex-col justify-center align-middle">
					<img class="flex-none mx-auto" style="height: 256px;"
						src="/suenabien.png"
						alt="1st Feb 2025, Malphino, Where's Rei, abnd DJ Luca in West Norwood Portico Gallery"
						width={256}
						height={256} />
				</div>
			</div>
		<figcaption class="px-6 pt-2 pb-8 text-xl">
			<p class="text-xl leading-10 font-light pb-2 ">
				<span class="font-bold ">Suena Bien</span> <span class="px-2 text-2xl"> 🔊 💃</span> <span class="whitespace-nowrap">a soundsystem for dancing.</span>
			</p>
			<p class="text-xl">Making speakers. Playing music. Partying together.</p>
			<p class="pt-4">Strictly good vibes in West Norwood since 2024.</p>
			<p class="pt-4">Powered by <a href="https://www.instagram.com/fig.g/">fig.g</a>, <a href="https://oli.zilla.org.uk/">olizilla</a>, <a href="https://www.instagram.com/malphino/">malphino</a> and you 🫵</p>
		</figcaption>
		</figure>
	</div>

  <script>
    // Get all post cards
    const cards = document.querySelectorAll('.post-card');

    cards.forEach((card) => {
      const mainImg = card.querySelector('.main-post-image') as HTMLImageElement;
      const thumbBtns = card.querySelectorAll('.thumbnail-btn');
      const details = card.querySelector('details');

      // Clicking main image toggles details element open state
      if (mainImg && details) {
        mainImg.addEventListener('click', () => {
          details.open = !details.open;
        });
      }

      if (thumbBtns.length > 0 && mainImg) {
        // Initially set the first thumbnail as active/highlighted
        thumbBtns[0].classList.add('ring-2', 'ring-red-950');

        thumbBtns.forEach((btn) => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const thumbImg = btn.querySelector('img');
            if (thumbImg) {
              // Copy both src and srcset to avoid browser loading lower-res files
              mainImg.src = thumbImg.src;
              if (thumbImg.srcset) {
                mainImg.srcset = thumbImg.srcset;
              } else {
                mainImg.removeAttribute('srcset');
              }

              // Update active highlight class
              thumbBtns.forEach((b) => b.classList.remove('ring-2', 'ring-red-950'));
              btn.classList.add('ring-2', 'ring-red-950');
            }
          });
        });
      }
    });
  </script>
</Layout>
